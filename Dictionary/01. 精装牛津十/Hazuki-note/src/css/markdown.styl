.md {
    $font-size-headings-step = .125em;
    $font-size-headings-base = 1.625em;
    $font-family-base = Mulish, 'Source Han Serif CN', sans-serif;

    h1, h2, h3, h4, h5, h6 {
        font-family: $font-family-base;
        font-style: normal;
        font-weight: bold;
        line-height: 1.5;
        margin: 1.25rem 0 .9375rem;

        &:first-child {
            margin-top: unset;
        }
    }

    for n in 1 .. 6 {
        h{n} {
            font-size: $font-size-headings-base - $font-size-headings-step * n;
        }
    }

    h1 {
        padding-bottom: .3em;
        border-bottom: 1px solid var(--grey-3);
    }

    blockquote, p, pre, table {
        margin: 0 0 .8rem;

        &:last-child {
            margin-bottom: unset;
        }
    }

    blockquote {
        font-family: $font-family-base;
        font-size: .9em;
        padding: .625rem 1.25rem;
        border-left: .25rem solid var(--primary-color);
        border-radius: .1875rem;
    }

    hr {
        border: none;
        border-bottom: 1px solid var(--grey-3);
        margin: 1.25rem 0;
    }

    pre {
        font-family: monospace;
        padding: 1rem;
        background: var(--grey-2);
        overflow: auto;
    }

    table {
        font-family: $font-family-base;
        font-size: .9em;
        color: var(--text-color);
        border-collapse: collapse;

        tbody tr {
            &:nth-of-type(odd) {
                background: var(--grey-1);
            }

            &:hover {
                background: var(--grey-2);
            }
        }

        caption, th, td {
            font-weight: normal;
            text-align: left;
            padding: .5rem;
        }

        th, td {
            border: .0625rem solid var(--grey-3);
        }

        th {
            font-weight: bold;
            text-align: center;
            padding-bottom: .625rem;
            border-bottom-width: .1875rem;
        }
    }

    /* list */
    li {
        list-style: none;
    }

    /* markdown-it-toc-and-anchor */
    h1, h2, h3, h4, h5, h6 {
        .anchor {
            float: right;
            color: var(--grey-4);
            margin-left: .625rem;
            transition();

            &:hover {
                color: inherit;
            }
        }
    }

    /* markdown-it-mark */
    mark {
        color: #b8860b;
        background: #fff4d6;
    }

    mark.red, .danger mark {
        color: #e9546b;
        background: var(--color-red-a1);
    }

    mark.green, .success mark {
        color: #2e8b57;
        background: #e6f4ea;
    }

    mark.blue, .info mark {
        color: #3794ff;
        background: #e3efff;
    }

    mark.purple, .primary mark {
        color: #8a51c0;
        background: #f2f0f7;
    }
}
